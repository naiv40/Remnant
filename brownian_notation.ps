/textmode-array 0 array def
/drawmode-array 0 array def

/textmode {
    /ltext exch def
    /larray textmode-array length 1 add array def
    0 1 textmode-array length 1 sub {
      /i exch def
      larray i textmode-array i get put
    }for
    larray textmode-array length ltext put
    /textmode-array larray def
}def

/drawmode {
    /ldraw exch def
    /larray drawmode-array length 1 add array def
    0 1 drawmode-array length 1 sub {
      /i exch def
      larray i drawmode-array i get put
    }for
    larray drawmode-array length ldraw put
    /drawmode-array larray def
}def

/current-draw_item 0 def
/dx 0 def
/dy 0 def

/drawings-xy-extension {
    /number-of-draw-pathes 1 def
    /llx-max  100000 def
    /lly-max  100000 def
    /urx-max -100000 def
    /ury-max -100000 def
    drawmode-array current-draw_item get cvx exec
    /all-draw-pathes number-of-draw-pathes 1 sub array def
    /currentpointx 0 def
    /currentpointy 0 def
    0 1 number-of-draw-pathes 2 sub {
	/lnum1 exch def
	/drawpath-name lnum1 1 add make-drawpath-name def
	/drawpath-name drawpath-name 1 drawpath-name length 1 sub getinterval def %cut the slash at the beginning
	all-draw-pathes lnum1 drawpath-name put
	newpath currentpointx currentpointy moveto drawpath-name cvx exec pathbbox
	/ury exch def
	/urx exch def
	/lly exch def
	/llx exch def

	%stroke lines: enlarge by linewidth/2
	draw-type (stroke) eq {
	    /lly lly current_linewidth 2 div sub def
	    /llx llx current_linewidth 2 div sub def
	    /ury ury current_linewidth 2 div add def
	    /urx urx current_linewidth 2 div add def
	}if

	llx llx-max lt {/llx-max llx def}if
	lly lly-max lt {/lly-max lly def}if
	urx urx-max gt {/urx-max urx def}if
	ury ury-max gt {/ury-max ury def}if
    }for

    /dx urx-max llx-max sub draw-dxy add def
    /dy ury-max lly-max sub draw-dxy add def
    positions-draw-dy  current-draw_item dy          put 
    positions-draw-dx  current-draw_item dx          put 
    positions-draw-llx current-draw_item llx-max     put  
    positions-draw-ury current-draw_item ury-max     put  
}def

/drawings {
    /number-of-draw-pathes 1 def
    drawmode-array current-draw_item get cvx exec
    /all-draw-pathes number-of-draw-pathes 1 sub array def
    /currentpointx current-drawx def
    /currentpointy current-drawy def
    0 1 number-of-draw-pathes 2 sub {
	/lnum1 exch def
	/drawpath-name lnum1 1 add make-drawpath-name def
	/drawpath-name drawpath-name 1 drawpath-name length 1 sub getinterval def %cut the slash at the beginning
	all-draw-pathes lnum1 drawpath-name put
	/savex currentpointx def
	/savey currentpointy def

	newpath savex savey moveto drawpath-name cvx exec draw-type (fill) eq {
	    draw-color 0 get
	    draw-color 1 get
	    draw-color 2 get setrgbcolor
  	    eofill
	}
	{
	    draw-color 0 get
	    draw-color 1 get
	    draw-color 2 get setrgbcolor
  	    stroke
	}ifelse
    }for
}def

/modes {
  1.8 1.8 scale
  /text-xa 2 def
  /text-dy 5 def
  /draw-dxy 2 def
  /draw-maxx 0 def
  /draw-maxy 0 def
  /content-maxy text-dy textmode-array length mul text-dy .2 mul add def
  /text-maxy 0 def
  /text-maxx 0 def
  /current-draw_item 0 def
  /current-drawy 0 def
  /current-drawx 0 def
  /positions-drawx    drawmode-array length array def
  /positions-drawy    drawmode-array length array def
  /positions-draw-dx  drawmode-array length array def
  /positions-draw-dy  drawmode-array length array def
  /positions-draw-llx drawmode-array length array def
  /positions-draw-lly drawmode-array length array def
  /positions-draw-urx drawmode-array length array def
  /positions-draw-ury drawmode-array length array def
  /positions-text-llx textmode-array length array def
  /positions-text-lly textmode-array length array def
  /positions-text-urx textmode-array length array def
  /positions-text-ury textmode-array length array def
  /scale-factor 1 def
  /number-of-draw-pathes 0 def
  /Lucida-ISOLatin1 findfont text-dy 0.9 mul scalefont setfont

  %%%%%%%%%%%%%maxixmal x-extension of text%%%%%%%%%%%%%%%%%%
  0 1 textmode-array length 1 sub {
    /i exch def
    0 0 moveto
    textmode-array i get true charpath pathbbox
    /ury exch def
    /urx exch def
    /lly exch def
    /llx exch def

    positions-text-llx i llx         put  
    positions-text-ury i ury         put  

    /dx urx llx sub def
    urx text-maxx gt {/text-maxx urx def}if
  }for
  /text-maxx text-maxx text-xa add def
  /right-maxx-for-drawings modes-maxx text-maxx sub def

  %%%%%%%%%%%%%%placement of drawings on right side%%%%%%%%%%%%%%
  /draw-maxy 0 def
  /current-drawx text-maxx def
  {
    current-draw_item drawmode-array length eq {exit}if 
    current-drawy content-maxy ge {exit}if 
    drawings-xy-extension

    %if there is no space for graphics on the right side draw at bottom
    current-draw_item 0 gt {
      text-maxx dx add modes-maxx gt {exit}if
    }
    {
      text-maxx dx add draw-maxx gt {/draw-maxx text-maxx dx add def}if
    }ifelse
    
    positions-drawx current-draw_item current-drawx put  %store xposition of drawing
    positions-drawy current-draw_item current-drawy put  %store yposition of drawing
    dy draw-maxy gt {/draw-maxy dy def}if
    
    current-drawx dx add modes-maxx gt
    current-draw_item 0 gt and {
	/current-drawx text-maxx dx sub def
        current-drawy draw-maxy add content-maxy ge {exit}if 
	/current-drawy current-drawy draw-maxy add def
	/draw-maxy 0 def
        positions-drawx current-draw_item current-drawx dx add put  %store xposition of drawing
        positions-drawy current-draw_item current-drawy put  %store yposition of drawing
    }if

    /current-drawx     current-drawx dx    add def
    /current-draw_item current-draw_item 1 add def
    current-drawx draw-maxx gt {/draw-maxx current-drawx def}if
    current-draw_item 1 eq text-maxx dx add modes-maxx gt and {exit}if
  }loop
  content-maxy current-drawy draw-maxy add lt {/content-maxy current-drawy draw-maxy add def}if
  current-drawy content-maxy lt {/current-drawy content-maxy def}if 
  %%%%%%%%%%%%%%placement of drawings at the bottom%%%%%%%%%%%%%%
  /current-drawx 0 def
  /draw-maxy 0 def
  {
    current-draw_item drawmode-array length eq {exit}if
    
    drawings-xy-extension
    positions-drawx current-draw_item current-drawx put  %store xposition of drawing
    positions-drawy current-draw_item current-drawy put  %store yposition of drawing
    
    dy draw-maxy gt {/draw-maxy dy def}if
    current-drawx dx add modes-maxx gt {
	/content-maxy content-maxy draw-maxy add def
	/current-drawx 0 def
	/content-maxy content-maxy draw-maxy add def
	/draw-maxy 0 def
    }if
    /current-drawx     current-drawx dx    add def
    /current-draw_item current-draw_item 1 add def
  }loop
  /content-maxy content-maxy draw-maxy add def

  %%%%%%%%%%%%%%%%%%%%%%scale if necessary%%%%%%%%%%%%%%%%%%%%%%%%
  gsave
  content-maxy draw-dxy add modes-maxy gt {/scale-factor modes-maxy content-maxy draw-dxy add div def}if
  text-maxx modes-maxx gt {
    modes-maxx text-maxx div scale-factor lt {
      /scale-factor modes-maxx text-maxx div def
    }if
  }if

  modes-maxx draw-maxx lt 
  {
    modes-maxx draw-maxx div scale-factor lt
    {
      /scale-factor modes-maxx draw-maxx div def
    }if
  }if

  scale-factor scale-factor scale
  /modes-maxx modes-maxx scale-factor div def
  
  %%%%%%%%%%%%%%%%%%%%%write text%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
  gsave
  /Lucida-ISOLatin1 findfont text-dy 0.9 mul scalefont setfont
  text-xa content-maxy text-dy 0.8 mul sub translate
  0 1 textmode-array length 1 sub {
    /i exch def
    0 0 moveto
    textmode-array i get show
    0 text-dy neg translate
  }for
  grestore
  %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
  0 1 drawmode-array length 1 sub {
    /current-draw_item exch def
    /current-drawx
      positions-drawx    current-draw_item get
      positions-draw-llx current-draw_item get sub
      draw-dxy add def
    /current-drawy content-maxy
      positions-drawy    current-draw_item get sub
      positions-draw-ury current-draw_item get sub
      def
    drawings
  }for
  grestore
}def

/showinstrument {
  /text-array exch def
  /Palatino-Roman findfont instrument-fontsize scalefont setfont
  /maxdx 0 def
  newpath 0 0 moveto
  text-array 0 get true charpath pathbbox
	/ury exch def
	/urx exch def
	/lly exch def
	/llx exch def
    /dy ury lly sub def

    text-array {
    newpath 0 0 moveto 
    true charpath pathbbox
	/ury exch def
	/urx exch def
	/lly exch def
	/llx exch def
    urx llx sub maxdx gt {/maxdx urx llx sub def}if
  }forall
  maxdx instrument-maxx gt {
    /instrument-fontsize instrument-fontsize instrument-maxx maxdx div mul def
    /instrument-textdy   instrument-textdy   instrument-maxx maxdx div mul def
    /dy                  dy                  instrument-maxx maxdx div mul def
  }if
  /y0 instrument-maxy 2 div text-array length 1 sub instrument-textdy mul dy add 2 div sub def
  /Palatino-Roman findfont instrument-fontsize scalefont setfont
  text-array length 1 sub -1 0 {
    /i exch def
    /text text-array i get def
    newpath 0 0 moveto 
    text true charpath pathbbox
	/ury exch def
	/urx exch def
	/lly exch def
	/llx exch def
urx llx sub 7 string cvs print ( ) print
   instrument-maxx 2 div urx llx sub 2 div sub llx sub y0 moveto
    text show
    /y0 y0 instrument-textdy add def
  }for
}def

/start_orchestration {
    gsave
    0 voice_ysize neg translate
}def

/end_orchestration {
    grestore
    xspace_between_voices_percentage 100 div 1 add voice_xsize mul 0 translate
}def

/orchestration_number {
    /lnumber exch def
    /Helvetica findfont 12 scalefont setfont
    0 voice_ysize moveto
    (orch ) show lnumber 4 string cvs show
}def

/start_voice {
  /notes-text-y0    38 def
    gsave
    0 .3 .7 setrgbcolor
    1 setlinewidth
    draw_voice_frame {-10 -30 voice_xsize voice_ysize rectstroke}if
}def

/end_voice {
    grestore
    0 yspace_between_voices_percentage 100 div 1 add voice_ysize mul -1 mul translate
}def

/voice_number {
    /lnumber exch def
    /Helvetica findfont 8 scalefont setfont
    0 setgray
    0 60 moveto
    (voice ) show lnumber 4 string cvs show
}def

/start_dynamics {
    gsave
    50 -30 translate
    0 setgray
    /Scriabin findfont Scr_fontsize scalefont setfont
}def

/end_dynamics {
    grestore
}def

/start_notes {
    gsave
    50 0 translate
    /Scriabin findfont Scr_fontsize scalefont setfont
    0 setgray
}def

/end_notes {
    grestore
}def

/start_keys {
    gsave
    30 00 translate
    0 setgray
}def

/end_keys {
    grestore
}def

/start_modes {
    gsave
    50 50 translate
    /textmode-array 0 array def
    /drawmode-array 0 array def
    0 setgray
}def

/end_modes {
  modes
    grestore
}def

/start_instrument {
    gsave
    0 -12 translate
    0 setgray
}def

/end_instrument {
    grestore
}def

/start_page {
    gsave
}def

/end_page {
    showpage
    grestore
}def

2 dict dup /PageSize [page_xsize page_ysize] put dup /ImagingBBox null put setpagedevice

40 page_ysize 30 sub translate
page_scale page_scale scale

