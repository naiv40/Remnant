/Palatino-Roman findfont dup length dict begin
{ 1 index /FID ne {def} {pop pop} ifelse }forall /Encoding ISOLatin1Encoding def currentdict end
/Lucida-ISOLatin1 exch definefont pop

        /pitchstep         2 def
        /Scr_fontsize     16 def
	/notehead_xoffset  10 def
	/accident_xoffset  3 def
	/notehead_dx      6 def % x-width of a notehead
	/accident_dx      6 def % x-width of an accident
	/key_dx           14 def % x-width of a key

%future version: fingerings in other versions
/setlanguage {
    /llanguage exch def
}def


/text_in_note {
    /ltext exch def
    gsave
    /Lucida-ISOLatin1 findfont 8 scalefont setfont
    0 0 moveto ltext true charpath pathbbox
	/ury exch def
	/urx exch def
	/lly exch def
	/llx exch def
	/dx urx llx sub 8 add all_scale mul def
	dx notes-maxx gt { /Lucida-ISOLatin1 findfont 8 notes-maxx mul dx div scalefont setfont}if
    1 notes-text-y0 moveto ltext show
    /notes-text-y0 notes-text-y0 notes-text-dy sub def
    grestore
}def

/percussivedown {
/noteheadhight exch def
gsave 0 noteheadhight pitchstep mul translate
  0.3 setlinewidth 0 -1 moveto 0 -14 rlineto stroke
  /Scriabin findfont Scr_fontsize scalefont setfont
  -.1 -7 moveto (\307) show
grestore
}def
/percussiveup {
/noteheadhight exch def
gsave 0 noteheadhight pitchstep mul translate
  0.3 setlinewidth 4.3 1 moveto 0 14 rlineto stroke
  /Scriabin findfont Scr_fontsize scalefont setfont
  -.2 7.6 moveto (\152) show
grestore
}def
/currentpointx 0 def
/currentpointy 0 def
/getcurrentpoint {
currentpoint /currentpointy exch def /currentpointx exch def 
}def
/offcurveto {
  /yoff exch def 
  /xoff exch def 
  /y3   exch def 
  /x3   exch def 
  /y2   exch def 
  /x2   exch def 
  /y1   exch def 
  /x1   exch def 
  x1 xoff sub 0.25 mul y1 yoff sub 0.25 mul neg
  x2 xoff sub 0.25 mul y2 yoff sub 0.25 mul neg
  x3 xoff sub 0.25 mul y3 yoff sub 0.25 mul neg curveto
}def

/music_ledgerline_down {
 0.5 setlinewidth newpath 17 27 30 255 285 arc stroke
}def
/music_ledgerline_up {
 1 -1 scale
 0.5 setlinewidth newpath 17 27 30 255 285 arc stroke
 1 -1 scale
}def

/base_staff_x_extension 0 def
/drawstaff {
  /maximal_notehead_offset   exch def
  /maximal_accident_offset   exch def
  /staff_yend                exch def
  /staff_ystart              exch def
  /dx 20 accident_dx maximal_accident_offset mul add notehead_dx maximal_notehead_offset mul add def
  /base_staff_x_extension dx def
    0.4 setlinewidth
    staff_ystart 1 staff_yend {/ly exch def
      0 ly pitchstep mul 2 mul moveto
      dx 0 rlineto stroke
    }for
}def

/drawstaff+key {
  /maximal_notehead_offset   exch def
  /maximal_accident_offset   exch def
  /key_drawn                 exch def
  /dx 20 accident_dx maximal_accident_offset mul add notehead_dx maximal_notehead_offset mul add def
  key_drawn {/dx dx key_dx add def}if
  /base_staff_x_extension dx base_staff_x_extension add 5 sub def
    0.4 setlinewidth
    0 1 4 {/ly exch def
      0 ly pitchstep mul 2 mul moveto
      dx 0 rlineto stroke
    }for
}def

/key_octave_down {
  /loctave exch def
  /lkey    exch def
  0 0 moveto lkey show 
      /Helvetica findfont pitchstep 4 mul scalefont setfont
    7 loctave length 3 mul sub -2 pitchstep mul moveto loctave show 
}def

/key_octave_up {
  /loctave exch def
  /lkey    exch def

    0 0 moveto lkey show
      /Helvetica findfont pitchstep 4 mul scalefont setfont
    7 loctave length 3 mul sub 12 pitchstep mul moveto loctave show 

}def

/15bass {
  (?) (15) key_octave_down
}def
/8bass {
  (?) (8) key_octave_down
}def
/bass {
  (?) () key_octave_down
}def
/tenor {
  (B) () key_octave_down
}def
/viola {
  (B) () key_octave_down
}def
/8violin {
  (&) (8) key_octave_down
}def
/violin {
  (&) () key_octave_down
}def
/violin8 {
  (&) (8) key_octave_up
}def
/violin15 {
  (&) (15) key_octave_up
}def
/violin22 {
  (&) (22) key_octave_up
}def
/violin29 {
  (&) (29) key_octave_up
}def

/bracket_note  {
    /notehead    exch def
    /pitchoffset exch def
    /accident    exch def
    /key         exch def
    gsave
    base_staff_x_extension 0 translate
    key (---) ne 0 0 drawstaff+key
    key (---) ne {
	key cvx exec
	key_dx 0 translate
    }if
    0 0 pitchoffset notehead cvx exec
    0 pitchoffset   accident cvx exec
    /Helvetica findfont 10 scalefont setfont
    0 pitchoffset 1.5 sub pitchstep mul moveto ((     )) show
    grestore
}def

/ledger_lines {
    /lpitchy exch def
    /xoffset exch def
    lpitchy staff_ystart 2 mul 1 sub lt {
      0.4 setlinewidth
      staff_ystart 1 sub -1 lpitchy 2 div {/ly exch def
        xoffset -1.5 add ly pitchstep mul 2 mul moveto 8 0 rlineto stroke
      }for
    }if
    lpitchy staff_yend 2 mul 1 add gt {
      0.4 setlinewidth
      staff_yend 1 add 1 lpitchy 2 div {/ly exch def
        xoffset -1.5 add ly pitchstep mul 2 mul moveto 8 0 rlineto stroke
      }for
    }if
}def

/ordinario_notehead {
  gsave
  /ly exch def
  /notehead_arrangement_offset   exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset notehead_xoffset
     accident_arrangement_offset accident_dx mul add
     notehead_arrangement_offset notehead_dx mul add def
  xoffset ly pitchstep mul moveto
  (\366) show %notehead
  xoffset ly ledger_lines
  grestore
}def

 
 /harmonic_notehead {
   gsave
   /ly exch def
   /notehead_arrangement_offset   exch def
   /accident_arrangement_offset   exch def
   /Scriabin findfont Scr_fontsize scalefont setfont
   /xoffset notehead_xoffset
      accident_arrangement_offset accident_dx mul add
      notehead_arrangement_offset notehead_dx mul add def
   xoffset ly pitchstep mul moveto
    (\117) show %diamond
    xoffset ly ledger_lines
    grestore
 }def
/noise_notehead {
  gsave
  /ly exch def
  /notehead_arrangement_offset   exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset notehead_xoffset
     accident_arrangement_offset accident_dx mul add
     notehead_arrangement_offset notehead_dx mul add def
     .7 setlinewidth
  xoffset ly .9 sub pitchstep mul 4.5 pitchstep 1.7 mul rectstroke
  xoffset ly ledger_lines
  grestore
}def

/slap_notehead {
  gsave
  /ly exch def
  /notehead_arrangement_offset   exch def
  /accident_arrangement_offset   exch def
  /Courier findfont pitchstep 5 mul scalefont setfont
  /xoffset notehead_xoffset
     accident_arrangement_offset accident_dx mul add
     notehead_arrangement_offset notehead_dx mul add def
  xoffset 1.0 sub ly 1.5 sub pitchstep mul moveto
  ly 4 gt { (>) } {(<) }ifelse show
  xoffset ly ledger_lines
  grestore
}def

/keynoise_notehead {
  gsave
  /ly exch def
  /notehead_arrangement_offset   exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset notehead_xoffset
     accident_arrangement_offset accident_dx mul add
     notehead_arrangement_offset notehead_dx mul add def
  xoffset ly pitchstep mul moveto
   (\277) show %keynoise notehead
   xoffset ly ledger_lines
   grestore
}def

/---_notehead {
}def

/bbb-accident {
  /ly exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
   accident_xoffset
     accident_arrangement_offset accident_dx mul add
   ly pitchstep mul
   moveto
   (\313) show %bb
}def

/-34-accident {
  /ly exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset accident_xoffset
     accident_arrangement_offset accident_dx mul add def

   xoffset 2.2 add ly pitchstep mul moveto
   (b) show
  gsave
  -1 1 scale
  xoffset -1 mul 1.8 sub ly pitchstep mul moveto
  (b) show
  grestore
}def

