/+14-accident {
  /ly exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset accident_xoffset
  accident_arrangement_offset accident_dx mul add def
    gsave
  xoffset 0 translate
  pitchstep pitchstep scale
  newpath 0 ly .1 add moveto  2 .6 rlineto 0 .5 rlineto -2 -.6 rlineto closepath fill
  newpath 0 ly -1.5 add moveto  2 .6 rlineto 0 .5 rlineto -2 -.6 rlineto closepath fill
  newpath 0.85 ly -2 add 0.3 4 rectfill
  grestore 
}def

/shp-accident {
  /ly exch def
