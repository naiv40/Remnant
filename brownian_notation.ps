  /flutes_s_f  {
      /fingering exch def
      /flutes_is_right false def
      /flutes_rightEbkey false def
      /flutes_rightEbC#Ckey false def
      /flutes_rightEbC#CHkey false def
      gsave
      0 -14 translate
      flutes_fingerings_scale flutes_fingerings_scale scale
      fingering {
  	/key exch def
  
  	key (//) eq {/flutes_is_right       true def}if
  	key (D#) eq {/flutes_rightEbkey     true def}if
  	key (C#) eq {/flutes_rightEbC#Ckey  true def}if
  	key (C)  eq {/flutes_rightEbC#Ckey  true def}if
  	key (B)  eq {/flutes_rightEbC#CHkey true def}if
  
  	key (//) ne {
      	  /basename flutes_is_right {(flutes_right)}{(flutes_left)} ifelse def
