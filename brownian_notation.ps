     closepath
     fillgraphic}end-path-element
   }if

   %16
    lcode 8 and 0 gt {
   new-path-element  {
currentpointx  -0.00000 local_scale_factor mul sub currentpointy  -0.50000 local_scale_factor mul sub   0.2 local_scale_factor mul 270 -90 arcn
closepath
   fillgraphic}end-path-element
   }if

}def

