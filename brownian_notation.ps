  /keyy -130 def
  
    /clarinet_i_ii_iii_iv_template {
      0 setgray 2 setlinewidth
      Klarinette_i_path stroke
      Klarinette_ii_path stroke
      Klarinette_iii_path stroke
      Klarinette_iv_path stroke
    }def
  
    /getkeyy {
    /keyy keyy 15 sub def
    keyy
  }def
  
    /start_clarinet_fingering {
      gsave
      .3 .3 scale
      40 80 translate
    }def
  
    /end_clarinet_fingering {
      0 setgray 2 setlinewidth
      Klarinette_T_path stroke
      Klarinette_1_path stroke
      Klarinette_2_path stroke
      Klarinette_3_path stroke
      Klarinette_4_path stroke
      Klarinette_5_path stroke
      Klarinette_6_path stroke
      5 setlinewidth
      -15 -67.5 moveto 30 0 rlineto stroke
      clarinet_i_ii_iii_iv_flag {clarinet_i_ii_iii_iv_template}if
      grestore
    }def
  
  /start_clarinet_keynoise {
      gsave 
      47 26 translate
      .27 .27 scale
  }def
  
  /clarinet_keynoise_arrow {
      newpath 30 -180 moveto 30 0 rlineto -3 -10 rlineto 24 14 rlineto -24 14 rlineto 3 -10 rlineto -30 0 rlineto closepath fill
  }def
  
  /clarinet_keynoise_tremolo {
      newpath 30 -170 moveto 3 10 rlineto -24 -14 rlineto 24 -14 rlineto -3 10 rlineto 
                           30 0 rlineto -3 -10 rlineto 24 14 rlineto -24 14 rlineto 3 -10 rlineto -30 0 rlineto closepath fill
  }def
  
  /end_clarinet_keynoise {
      0 setgray 2 setlinewidth
      Klarinette_T_path stroke
      Klarinette_1_path stroke
      Klarinette_2_path stroke
      Klarinette_3_path stroke
      Klarinette_4_path stroke
      Klarinette_5_path stroke
      Klarinette_6_path stroke
      clarinet_i_ii_iii_iv_flag {clarinet_i_ii_iii_iv_template}if
      5 setlinewidth
      -15 -67.5 moveto 30 0 rlineto stroke
      grestore
  }def
  
    /Klarinette_T_path     {newpath -25 0 10 0 360      arc closepath}def
    /Klarinette_1_path     {newpath 0 0 10 0 360        arc closepath}def
    /Klarinette_2_path     {newpath 0 -25 10 0 360      arc closepath}def
    /Klarinette_3_path     {newpath 0 -50 10 0 360      arc closepath}def
    /Klarinette_4_path     {newpath 0 -85 10 0 360      arc closepath}def
    /Klarinette_5_path     {newpath 0 -110 10 0 360     arc closepath}def
    /Klarinette_6_path     {newpath 0 -135 10 0 360     arc closepath}def
    /Klarinette_i_path     {-27 -80 translate 0.7 0.3 scale newpath 0 0 10 0 360 arc 1 0.7 div 1 0.3 div scale 27 80 translate closepath}def
    /Klarinette_ii_path    {-27 -70 translate 0.7 0.3 scale newpath 0 0 10 0 360 arc 1 0.7 div 1 0.3 div scale 27 70 translate closepath}def
    /Klarinette_iii_path   {-27 -60 translate 0.7 0.3 scale newpath 0 0 10 0 360 arc 1 0.7 div 1 0.3 div scale 27 60 translate closepath}def
    /Klarinette_iv_path    {-27 -50 translate 0.7 0.3 scale newpath 0 0 10 0 360 arc 1 0.7 div 1 0.3 div scale 27 50 translate closepath}def
  
    /Klarinette_T     {Klarinette_T_path colouredfill}def
    /Klarinette_1half {gsave 0 0    translate 1 1 scale newpath 0 0 10 0 180 arc closepath colouredfill      grestore}def
    /Klarinette_1     {Klarinette_1_path colouredfill}def
    /Klarinette_2     {Klarinette_2_path colouredfill}def
    /Klarinette_3     {Klarinette_3_path colouredfill}def
  
    /Klarinette_A     {0 setgray gsave -5 14  translate 0 0 moveto /Helvetica findfont 16  scalefont setfont (A) show  grestore}def
    /Klarinette_R     {0 setgray gsave -30 14 translate 0 0 moveto /Helvetica findfont 16  scalefont setfont (R) show  grestore}def
    /Klarinette_G#    {0 setgray gsave -10 14 translate 0 0 moveto /Helvetica findfont 16  scalefont setfont (G#) show grestore}def
    /Klarinette_Eb    {0 setgray gsave 15 -42 translate 0 0 moveto /Helvetica findfont 16  scalefont setfont (Eb) show grestore}def
    /Klarinette_C#_left    {0 setgray gsave 20 -68 translate 0 0 moveto /Helvetica findfont 16  scalefont setfont (C#) show grestore}def
  
    /Klarinette_4     {Klarinette_4_path colouredfill}def
    /Klarinette_5     {Klarinette_5_path colouredfill}def
    /Klarinette_6     {Klarinette_6_path colouredfill}def
    /Klarinette_i     {Klarinette_i_path colouredfill}def
