start_page
start_orchestration
1 orchestration_number
start_voice
1 voice_number
start_dynamics
      
  1 5 moveto
end_dynamics
start_keys
  /drawstaffkey {
    /maximal_notehead_offset   exch def
    /maximal_accident_offset   exch def
    /staff_yend                exch def
    /staff_ystart              exch def
    /dx 20 accident_dx maximal_accident_offset mul add notehead_dx maximal_notehead_offset mul add def
      0.4 setlinewidth
      staff_ystart 1 staff_yend {/ly exch def
        0 ly pitchstep mul 2 mul moveto
        dx 0 rlineto stroke
      }for
      /Scriabin findfont Scr_fontsize scalefont setfont
      2 0 moveto (?) show
  }def
  
  
  0 4 0 0 drawstaffkey
end_keys
start_modes
  (tongue\040ram) textmode
end_modes
start_instrument
  [(Cl) ] showinstrument
end_instrument
start_notes
  0 4 0 0 drawstaff
  0 0 8 ordinario_notehead
