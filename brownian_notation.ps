closepath
0 0.1 rmoveto_scale
getcurrentpoint
currentpointx  -0.00000 local_scale_factor mul sub currentpointy  -1.50000 local_scale_factor mul sub   1.50000 local_scale_factor mul 270 -90 arcn
    fillgraphic}end-path-element    

   new-path-element  {
     0.2 setlinewidth_scale
     -1.45 2 moveto_scale 2.94 0 rlineto_scale
   strokegraphic}end-path-element

   new-path-element  {
     0.2 setlinewidth_scale
     -1.45 1 moveto_scale 2.94 0 rlineto_scale
   strokegraphic}end-path-element

   %8
    lcode 2 and 0 gt {
   new-path-element  {
currentpointx  -0.00000 local_scale_factor mul sub currentpointy  -1.50000 local_scale_factor mul sub   0.2 local_scale_factor mul 270 -90 arcn
closepath
   fillgraphic}end-path-element
   }if

   %cassotto
    lcode 4 and 0 gt {
   new-path-element  {
     currentpointx  -0.80000 local_scale_factor mul sub currentpointy  -1.50000 local_scale_factor mul sub   0.2 local_scale_factor mul 270 -90 arcn
