  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset accident_xoffset
  accident_arrangement_offset accident_dx mul add def
  xoffset ly pitchstep mul moveto
  (#) show
}def

/+34-accident {
  /ly exch def
  /accident_arrangement_offset   exch def

  /xoffset accident_xoffset
    accident_arrangement_offset accident_dx mul add def
     
    gsave
    xoffset 0 translate
    pitchstep pitchstep scale
    newpath -.5 ly .1   add moveto  3 .6 rlineto 0 .5 rlineto -3 -.6 rlineto closepath fill
    newpath -.5 ly -1.5 add moveto  3 .6 rlineto 0 .5 rlineto -3 -.6 rlineto closepath fill
    newpath 0.05 ly -2 add 0.3 4 rectfill
    newpath 0.85 ly -2 add 0.3 4 rectfill
    newpath 1.65 ly -2 add 0.3 4 rectfill
    grestore 
}def

/++x-accident {
  /ly exch def
  /accident_arrangement_offset   exch def
  /Scriabin findfont Scr_fontsize scalefont setfont
  /xoffset accident_xoffset
  accident_arrangement_offset accident_dx mul add def
  xoffset ly pitchstep mul moveto
   (\302) show %Doppelkreuz
}def
/length_of_stem 9 def
/stem_low       0 def
/stem_high      0 def
/stem_x         0 def

/stem_up {
  /lpercussive             exch def
  /highest_zerooffset_note exch def
  /lowest_zerooffset_note  exch def
  /highest_note            exch def
  /lowest_note             exch def
  /accident_arrangement_offset   exch def
  /xoffset notehead_xoffset
  accident_arrangement_offset accident_dx mul add 4.5 add def
  /stem_x    xoffset      def
  /stem_low  highest_note def
  /stem_high stem_low length_of_stem add def
  0.5 setlinewidth
  xoffset 0.05 add lowest_zerooffset_note pitchstep mul moveto
  0 highest_note lowest_zerooffset_note sub length_of_stem add pitchstep mul rlineto stroke
  lpercussive {
    gsave
    /Scriabin findfont Scr_fontsize scalefont setfont
    xoffset 4.6 sub
    highest_note 4.5 add pitchstep mul moveto
    (\152) show
    xoffset 7 sub lowest_note 1 sub pitchstep mul translate
    music_ledgerline_down
    grestore
  }if
}def

/stem_down {
  /lpercussive                   exch def
  /highest_zerooffset_note       exch def
  /lowest_zerooffset_note        exch def
  /highest_note                  exch def
  /lowest_note                   exch def
  /accident_arrangement_offset   exch def
  /xoffset notehead_xoffset
    accident_arrangement_offset accident_dx mul add 0.1 add def
  /stem_x    xoffset      def
  /stem_high lowest_note def
  /stem_low  stem_high length_of_stem sub def
  0.5 setlinewidth
  xoffset highest_zerooffset_note pitchstep mul moveto
  0 lowest_note highest_zerooffset_note sub length_of_stem sub pitchstep mul rlineto stroke
  lpercussive {
    gsave
    1 -1 scale
    /Scriabin findfont Scr_fontsize scalefont setfont
    xoffset 4.7 sub
    lowest_note neg 12 add length_of_stem sub pitchstep mul moveto
    (\152) show
    grestore
    gsave
    xoffset 5 sub highest_note 1 add pitchstep mul translate
    music_ledgerline_up
    grestore
  }if
}def

/tremolo {
  gsave
  stem_x stem_high stem_low add 2 div pitchstep mul translate
  5 5 scale
  -0.5 -0.3 translate
  0 0 moveto
  0 0.18 rlineto
  0.951 0.309 rlineto
  0 -0.18 rlineto
  closepath
  0 0.25 moveto
  0 0.18 rlineto
  0.951 0.309 rlineto
  0 -0.18 rlineto
  closepath
  0 0.5 moveto
  0 0.18 rlineto
  0.951 0.309 rlineto
  0 -0.18 rlineto
  closepath
  fill
  grestore
}def

/harmonic_note_with_another_key  {
    /pitchoffset exch def
    /accident exch def
    /key exch def
    gsave
    base_staff_x_extension 0 translate
    key (---) ne 0 0 drawstaff+key
    key (---) ne {
	key cvx exec
	key_dx 0 translate
    }if
    0 0 pitchoffset harmonic_notehead
    0 pitchoffset accident cvx exec
    grestore
}def

/arpeggio_down {
  /ly exch def
  gsave
  12 ly pitchstep mul translate
  1 setlinewidth
  0 setgray
  -10 -12 moveto
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
  stroke
  newpath -10.5 -12.5 moveto 3 0 rlineto -3 3 rlineto closepath fill
  grestore
}def

/extra_note  {
    /notehead exch def
    /pitchoffset exch def
    /accident exch def
    /key exch def
    gsave
    base_staff_x_extension 0 translate
    key (---) ne 0 0 drawstaff+key
    key (---) ne {
	key cvx exec
	key_dx 0 translate
    }if
    0 0 pitchoffset notehead cvx exec
    0 pitchoffset accident cvx exec
    grestore
}def

/arpeggio_up {
  /ly exch def
  gsave
  12 ly pitchstep mul translate
  1 setlinewidth
  0 setgray
  -10 -12 moveto
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
   3 2 rlineto 
  -3 2 rlineto 
  stroke
  newpath -10.5 9.5 moveto 0 3 rlineto 3 0 rlineto closepath fill
  grestore
}def

/chord {
    /lmax_accident_xoffset exch def
    /lnotehead exch def
    /lkey      exch def
    /lchord    exch def
    lchord {
      /llist exch def
      /notehead_arrangement_offset llist 3 get def
      /laccident_arrangement_offset llist 2 get def
      /lly llist 1 get def
      /accident llist 0 get def
      lmax_accident_xoffset notehead_arrangement_offset lly lnotehead cvx exec
      laccident_arrangement_offset lly accident cvx exec
    }forall
}def

/p1p2rotate {
    point_angle 90 eq {
	/pa p2 neg def
	/pb p1     def
	/p1 pa     def
	/p2 pb     def
    }if
    point_angle 180 eq {
	/pa p1 neg def
	/pb p2 neg def
	/p1 pa     def
	/p2 pb     def
    }if
    point_angle -90 eq {
	/pa p2     def
	/pb p1 neg def
	/p1 pa     def
	/p2 pb     def
    }if
}def

/p3p4rotate {
    point_angle 90 eq {
	/pa p4 neg def
	/pb p3     def
	/p3 pa     def
	/p4 pb     def
    }if
    point_angle 180 eq {
	/pa p3 neg def
	/pb p4 neg def
	/p3 pa     def
	/p4 pb     def
    }if
    point_angle -90 eq {
	/pa p4     def
	/pb p3 neg def
	/p3 pa     def
	/p4 pb     def
    }if
}def

/p5p6rotate {
    point_angle 90 eq {
	/pa p6 neg def
	/pb p5     def
	/p5 pa     def
	/p6 pb     def
    }if
    point_angle 180 eq {
	/pa p5 neg def
	/pb p6 neg def
	/p5 pa     def
	/p6 pb     def
    }if
    point_angle -90 eq {
	/pa p6     def
	/pb p5 neg def
	/p5 pa     def
	/p6 pb     def
    }if
}def

/point_rotate {
    /point_angle exch def
}def
/fillgraphic {
    /draw-color [0 0 0] def
    /draw-type (fill) def
    /point_angle 0 def
}def

/colorfillgraphic {
    /lb exch def
    /lg exch def
    /lr exch def
    /draw-color [lr lg lb] def
    /draw-type (fill) def
    /point_angle 0 def
}def

/strokegraphic {
    /draw-color [0 0 0] def
    /draw-type (stroke) def
    /point_angle 0 def
}def

/colorstrokegraphic {
    /lb exch def
    /lg exch def
    /lr exch def
    /draw-color [lr lg lb] def
    /draw-type (stroke) def
    /point_angle 0 def
}def

/curveto_scale {
  local_scale_factor mul /y3   exch def 
  local_scale_factor mul /x3   exch def 
  local_scale_factor mul /y2   exch def 
  local_scale_factor mul /x2   exch def 
  local_scale_factor mul /y1   exch def 
  local_scale_factor mul /x1   exch def
  p1p2rotate
  p3p4rotate
  p5p6rotate
  x1 currentpointx add 
  y1 currentpointy add 
  x2 currentpointx add 
  y2 currentpointy add 
  x3 currentpointx add 
  y3 currentpointy add 
  curveto
}def

/offcurveto {
  /yoff exch def 
  /xoff exch def 
  /y3   exch def 
  /x3   exch def 
  /y2   exch def 
  /x2   exch def 
  /y1   exch def 
  /x1   exch def
  x1 xoff sub currentpointx add local_scale_factor mul y1 yoff sub neg currentpointy add local_scale_factor mul
  x2 xoff sub currentpointx add local_scale_factor mul y2 yoff sub neg currentpointy add local_scale_factor mul
  x3 xoff sub currentpointx add local_scale_factor mul y3 yoff sub neg currentpointy add local_scale_factor mul curveto
}def

/rlineto_scale {
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    p1  
    p2 
    rlineto
}def

/lineto_scale {
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    p1 currentpointx add  
    p2 currentpointy add  
    lineto
}def

/rmoveto_scale {
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    p1  
    p2 
    rmoveto
}def

/moveto_scale {
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    p1 currentpointx add  
    p2 currentpointy add  
    moveto
}def

/setlinewidth_scale {
    /current_linewidth exch def
    /current_linewidth current_linewidth local_scale_factor mul def
    current_linewidth setlinewidth 
}def

/rect_scale {
    local_scale_factor mul /p4 exch def
    local_scale_factor mul /p3 exch def
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def

    p1p2rotate
    p3p4rotate
    /p1 p1 currentpointx add def
    /p2 p2 currentpointy add def
    newpath p1 p2 moveto p3 0 rlineto 0 p4 rlineto p3 neg 0 rlineto closepath
}def

/arc_scale {
    /p5 exch def
    /p4 exch def
    local_scale_factor mul /p3 exch def
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    /p1 p1 currentpointx add def
    /p2 p2 currentpointy add def
    p1 
    p2 
    p3 
    p4
    p5
    arc
}def

/arcn_scale {
    /p5 exch def
    /p4 exch def
    local_scale_factor mul /p3 exch def
    local_scale_factor mul /p2 exch def
    local_scale_factor mul /p1 exch def
    p1p2rotate
    /p1 p1 currentpointx add def
    /p2 p2 currentpointy add def
    p1 
    p2 
    p3 
    p4
    p5
    arcn
}def

/make-drawpath-name {
    /lnum exch def
    /length-of-lnum lnum log cvi def
    /drawpath-name drawpath-rootname length 1 add length-of-lnum add string def
    drawpath-name 0 drawpath-rootname putinterval
    /lnum-string lnum length-of-lnum 1 add string cvs def
    drawpath-name drawpath-rootname length lnum-string putinterval
    drawpath-name
}def

/new-path-element {   %defines a routine with the name /drawpathxx (xx = 1,2,3,4...)
    number-of-draw-pathes make-drawpath-name cvx exec
}def

/end-path-element {
    def
    /number-of-draw-pathes number-of-draw-pathes 1 add def
}def

