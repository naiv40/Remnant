    lcode 1 and 0 gt {
      new-path-element {
        currentpointx  2 local_scale_factor mul add currentpointy  6 local_scale_factor mul add   1 local_scale_factor mul 270 -90 arcn
        closepath
        fillgraphic
      }end-path-element
   }if
}def

