  /topfingering [ (T) (A) (F_top) (D_octave) (Eb_octave) (F_octave) (Bb_plateau) (1) (2) (3) (Bb) (B) (G#) (C#)] def
  /bottomfingering [(4) (5) (6) (F#) (G) (Tf) (Eb_low) (C_low) (E) (Ta) (Tc)] def
  /stopfingering_set    topfingering    length string def
  /sbottomfingering_set bottomfingering length string def
  /etopfingering_set    topfingering    length string def
  /ebottomfingering_set bottomfingering length string def
  
  0 1 topfingering    length 1 sub {/lnum exch def stopfingering_set    lnum 48 put etopfingering_set    lnum 48 put }for
  0 1 bottomfingering length 1 sub {/lnum exch def sbottomfingering_set lnum 48 put ebottomfingering_set lnum 48 put }for
  
  /start_saxophone_keynoise {
    gsave 15 -30 translate  .3 .3 scale
  
  }def
  
  /saxophone_keynoise_arrow {
      newpath 120 67 moveto 30 0 rlineto -3 -10 rlineto 24 14 rlineto -24 14 rlineto 3 -10 rlineto -30 0 rlineto closepath fill
  }def
  
  /saxophone_keynoise_tremolo {
      newpath 130 67 moveto 3 10 rlineto -24 -14 rlineto 24 -14 rlineto -3 10 rlineto 
                           30 0 rlineto -3 -10 rlineto 24 14 rlineto -24 14 rlineto 3 -10 rlineto -30 0 rlineto closepath fill
  }def
  
  /end_saxophone_keynoise {
  0.7 setlinewidth 0 setgray
      saxophone1path  stroke
      saxophone2path  stroke
      saxophone3path  stroke
      saxophone4path  stroke
      saxophone5path  stroke
      saxophone6path  stroke
      0 setgray
      4 setlinewidth
      70 110 moveto 40 0 rlineto stroke
      grestore
  }def
  
  /top_end_saxophone_keynoise {
  0.7 setlinewidth 0 setgray
      saxophone1path  stroke
      saxophone2path  stroke
      saxophone3path  stroke
      0 setgray
      4 setlinewidth
      70 110 moveto 40 0 rlineto stroke
  }def
  
  /bottom_end_saxophone_keynoise {
  0.7 setlinewidth 0 setgray
      saxophone4path  stroke
      saxophone5path  stroke
      saxophone6path  stroke
      0 setgray
      4 setlinewidth
      -15.5 110 moveto 125.5 0 rlineto stroke
  }def
  
  /saxophones_s_f  {
      /fingering exch def
  
      fingering {
  	/key exch def
  	0 1 topfingering length 1 sub {
  	    /lnum exch def
  	    topfingering lnum get key eq {stopfingering_set lnum 49 put}if
  	}for
  	0 1 bottomfingering length 1 sub {
  	    /lnum exch def
  	    bottomfingering lnum get key eq {sbottomfingering_set lnum 49 put}if
  	}for
      }forall
      
      start_saxophone_keynoise
      fingering {
  	/key exch def
  	/basename (saxophone) def
  	/keyroutine basename length key length add string def
  	keyroutine 0 basename putinterval
  	keyroutine basename length key putinterval
  	keyroutine cvx exec
      }forall
      end_saxophone_keynoise
  }def
  
  /saxophones_f  {
    saxophones_s_f
  }def
  
  /saxophones_s_scale_f  {
    saxophones_s_f
  }def
  
  /saxophones_endfingering {
      125 0 translate
      stopfingering_set    etopfingering_set    ne {
        0 1 topfingering length 1 sub {
  	/lnum exch def
          etopfingering_set lnum get 49 eq
  	{
  	  /key topfingering lnum get def
  	  /basename (saxophone) def
  	  /keyroutine basename length key length add string def
  	  keyroutine 0 basename putinterval
  	  keyroutine basename length key putinterval
  	  keyroutine cvx exec
          }if
        }for
      }if
      sbottomfingering_set    ebottomfingering_set    ne {
        0 1 bottomfingering length 1 sub {
  	/lnum exch def
          ebottomfingering_set lnum get 49 eq
  	{
  	  /key bottomfingering lnum get def
  	  /basename (saxophone) def
  	  /keyroutine basename length key length add string def
  	  keyroutine 0 basename putinterval
  	  keyroutine basename length key putinterval
  	  keyroutine cvx exec
          }if
        }for
      }if
      stopfingering_set    etopfingering_set    ne {top_end_saxophone_keynoise}if
      sbottomfingering_set ebottomfingering_set ne {bottom_end_saxophone_keynoise}if
      grestore
  }def
  
  
  /saxophones_e_f  {
      /fingering exch def
      fingering saxophones_code_endfingering
      start_saxophone_keynoise
      saxophone_keynoise_arrow
      saxophones_endfingering
  }def
  
  /saxophones_code_endfingering  {
      /lfingering exch def
      lfingering {
  	/key exch def
  	0 1 topfingering length 1 sub {
  	    /lnum exch def
  	    topfingering lnum get key eq {etopfingering_set lnum 49 put}if
  	}for
  	0 1 bottomfingering length 1 sub {
  	    /lnum exch def
  	    bottomfingering lnum get key eq {ebottomfingering_set lnum 49 put}if
  	}for
      }forall
  }def
  
  /saxophones_t_f  {
      /fingering exch def
      fingering saxophones_code_endfingering
      start_saxophone_keynoise
      saxophone_keynoise_tremolo
      saxophones_endfingering
  }def
