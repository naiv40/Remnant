  /bottomfingering [(4) (5) (6) (F#) (G) (Tf) (Eb_low) (C_low) (E) (Ta) (Tc)] def
  /stopfingering_set    topfingering    length string def
  /sbottomfingering_set bottomfingering length string def
  /etopfingering_set    topfingering    length string def
  /ebottomfingering_set bottomfingering length string def
  
  0 1 topfingering    length 1 sub {/lnum exch def stopfingering_set    lnum 48 put etopfingering_set    lnum 48 put }for
  0 1 bottomfingering length 1 sub {/lnum exch def sbottomfingering_set lnum 48 put ebottomfingering_set lnum 48 put }for
  
